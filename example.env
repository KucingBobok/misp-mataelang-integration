# ══════════════════════════════════════════════════════════════════════════════
# MISP ↔ Mata Elang Integration Service v1.1 — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in ALL values marked with <REQUIRED>.
#
# Generate API keys with:
#   python scripts/generate_api_key.py --count 2
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=MISP-MataElang Integration Service
APP_VERSION=1.1.0
DEBUG=false
LOG_LEVEL=INFO

# ══════════════════════════════════════════════════════════════════════════════
# INTER-SERVICE AUTHENTICATION  ← NEW in v1.1
# ══════════════════════════════════════════════════════════════════════════════
# The service WILL NOT START if both of these are empty.
# Use SERVICE_API_KEY for a single key, or SERVICE_API_KEYS for multiple
# (comma-separated). Both can be set simultaneously.
#
# Generate: python scripts/generate_api_key.py
#
# Clients must send:  X-API-Key: <key>
# ─────────────────────────────────────────────────────────────────────────────
SERVICE_API_KEY=<REQUIRED: generate with scripts/generate_api_key.py>
# SERVICE_API_KEYS=key1,key2,key3   ← multiple keys (e.g. sensor1, sensor2, dashboard)

# Header name (default is fine in most cases)
API_KEY_HEADER=X-API-Key

# Comma-separated paths that bypass auth (no key required)
AUTH_EXEMPT_PATHS=/health,/docs,/redoc,/openapi.json,/

# ── MISP ─────────────────────────────────────────────────────────────────────
MISP_URL=<REQUIRED: https://misp.your-org.com>
MISP_API_KEY=<REQUIRED: your MISP API key from Administration > Auth Keys>
MISP_VERIFY_TLS=true      # Set false if MISP uses a self-signed certificate
MISP_TIMEOUT=30

# IOC filter — MISP attribute types to pull
MISP_IOC_TYPES=["ip-src","ip-dst","domain","hostname","url"]

# Only fetch IOCs published in this window (e.g. 24h, 7d, 30d)
MISP_PUBLISH_TIMESTAMP=24h
MISP_PAGE_SIZE=200
MISP_ENFORCE_WARNINGLIST=true

# ── Sync Scheduler ────────────────────────────────────────────────────────────
SYNC_INTERVAL_SECONDS=600   # 10 minutes; adjust to 300 (5m) for faster updates
SYNC_ENABLED=true

# ── Kafka (Mata Elang) ────────────────────────────────────────────────────────
# Mata Elang uses mTLS on port 19094 (EXTERNAL SSL listener)
KAFKA_BROKERS=broker:19094
KAFKA_SECURITY_PROTOCOL=SSL

# Paths inside the container — mounted from mataelang_certs volume
KAFKA_SSL_CA_LOCATION=/certs/ca.pem
KAFKA_SSL_CERT_LOCATION=/certs/client.pem
KAFKA_SSL_KEY_LOCATION=/certs/client.key
KAFKA_SSL_KEY_PASSWORD=<REQUIRED: SSL_PASSWORD from Mata Elang .env>

KAFKA_INPUT_TOPIC=snort_alerts          # Produced by event-stream-aggr
KAFKA_OUTPUT_TOPIC=misp_enriched_alerts
KAFKA_CONSUMER_GROUP_ID=misp-integration-service
KAFKA_AUTO_OFFSET_RESET=latest

# ── OpenSearch (Mata Elang) ───────────────────────────────────────────────────
OPENSEARCH_HOST=https://opensearch-node1:9200
# Recommended v1.1: run scripts/opensearch_setup.sh to create a dedicated user
OPENSEARCH_USERNAME=<REQUIRED: misp_integration_user (after running opensearch_setup.sh)>
OPENSEARCH_PASSWORD=<REQUIRED: password set in opensearch_setup.sh>
OPENSEARCH_VERIFY_CERTS=false    # Set true and mount CA cert in production
OPENSEARCH_INDEX_ENRICHED=misp-enriched-alerts
OPENSEARCH_INDEX_IOC=misp-ioc-store

# ══════════════════════════════════════════════════════════════════════════════
# REDIS IOC STORE  ← NEW in v1.1
# ══════════════════════════════════════════════════════════════════════════════
IOC_BACKEND=redis                        # "redis" (v1.1) | "memory" (v1.0 fallback)

REDIS_HOST=misp-redis                    # Service name in compose.misp.yml
REDIS_PORT=6379
REDIS_DB=0
# Must match --requirepass in compose.misp.yml Redis command
REDIS_PASSWORD=<REQUIRED: RedisSecurePassword@123 or your own strong password>
REDIS_TLS=false
REDIS_TLS_VERIFY=true
REDIS_POOL_MIN=2
REDIS_POOL_MAX=20
REDIS_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5

# Namespace prefix for all IOC keys in Redis
REDIS_KEY_PREFIX=mataelang:ioc

# IOC TTL in seconds (86400 = 24 h) — also applied as Redis EXPIRE
IOC_TTL_SECONDS=86400

# Bulk pipeline chunk size — 500 is a good default for most deployments
REDIS_PIPELINE_CHUNK=500

# ── Sighting Feedback ─────────────────────────────────────────────────────────
SIGHTING_ENABLED=true
SIGHTING_SOURCE=Mata Elang NIDS
